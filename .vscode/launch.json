{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Rust Backend (Actix)",
      "type": "lldb",
      "request": "attach",
      "pid": "${command:pickProcess}",
      "program": "/usr/local/cargo/bin/family-planner-backend",
      "sourceLanguages": ["rust"]
    },
    {
      "name": "Launch React Front-end",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "start"],
      "cwd": "${workspaceFolder}/frontend",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    },
    {
      "name": "Attach to LLM Service (Python)",
      "type": "python",
      "request": "attach",
      "connect": {
        "host": "127.0.0.1",
        "port": 5678
      },
      "pathMappings": [
        {
          "localRoot": "${workspaceFolder}/llm-service",
          "remoteRoot": "/app"
        }
      ]
    }
  ]
}
