{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Family Planner",
      "type": "shell",
      "command": "${workspaceFolder}/start-family-planner.sh",
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "runOptions": {
        "runOn": "folderOpen"
      }
    },
    {
      "label": "Stop Family Planner",
      "type": "shell",
      "command": "docker compose down",
      "problemMatcher": [],
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    }
  ]
}
