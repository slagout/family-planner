# ============================================================
# Family Planner � Production Environment Template
# Copy to .env and fill in ALL values before deploying
# ============================================================

# PostgreSQL
PGHOST=postgres
PGPORT=5432
PGDATABASE=family_planner
PGUSER=fp_user
PGPASSWORD=CHANGE_ME_STRONG_PASSWORD_32CHARS
PG_POOL_MAX=10
PG_SSL=false

# Application
NODE_ENV=production
PORT=4000
CORS_ORIGINS=https://CHANGE_ME_DOMAIN

# JWT (legacy - being replaced by Keycloak)
JWT_SECRET=CHANGE_ME_JWT_SECRET_64CHARS_MINIMUM_LENGTH_HERE

# Keycloak
KEYCLOAK_URL=https://auth.CHANGE_ME_DOMAIN
KEYCLOAK_REALM=family-planner
KEYCLOAK_CLIENT_ID=family-planner-app
KEYCLOAK_CLIENT_SECRET=CHANGE_ME_KEYCLOAK_CLIENT_SECRET

# Kroger API
KROGER_CLIENT_ID=CHANGE_ME_KROGER_CLIENT_ID
KROGER_CLIENT_SECRET=CHANGE_ME_KROGER_CLIENT_SECRET
KROGER_REDIRECT_URI=https://CHANGE_ME_DOMAIN/api/kroger/callback

# Encryption (for token storage)
ENCRYPTION_KEY=CHANGE_ME_32_BYTE_HEX_KEY_FOR_AES256

# Grafana
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD

# Traefik (Let's Encrypt)
LETSENCRYPT_EMAIL=CHANGE_ME@email.com
DOMAIN=CHANGE_ME_DOMAIN
ACME_CA_SERVER=https://acme-v02.api.letsencrypt.org/directory
