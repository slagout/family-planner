# Production Environment Variables Template
# Copy this to .env.prod and fill in the actual values

# ============================================================================
# Core Configuration
# ============================================================================
ENVIRONMENT=production
NODE_ENV=production

# Domain and Network
DOMAIN=family-planner.example.com
LETSENCRYPT_EMAIL=admin@example.com

# ============================================================================
# Database Configuration
# ============================================================================

# PostgreSQL (Primary Database)
POSTGRES_DB=family_planner
POSTGRES_USER=fp_user
POSTGRES_PASSWORD=change_me_to_secure_password

# PostgreSQL Advanced
POSTGRES_INITDB_ARGS=-c shared_buffers=256MB -c effective_cache_size=1GB

# ============================================================================
# MongoDB Configuration (Replica Set for HA)
# ============================================================================
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=change_me_to_secure_password
MONGO_REPLICA_SET=rs0

# ============================================================================
# Redis Configuration (Cache & Session Store)
# ============================================================================
REDIS_PASSWORD=change_me_to_secure_password
REDIS_TIMEOUT=300

# ============================================================================
# Authentication & Security
# ============================================================================

# JWT Secret (use: openssl rand -base64 64)
JWT_SECRET=change_me_to_very_long_secure_key_minimum_64_chars

# CORS Configuration
CORS_ORIGINS=https://family-planner.example.com,https://www.family-planner.example.com

# ============================================================================
# Keycloak Configuration (Identity Management)
# ============================================================================
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change_me_to_secure_password
KEYCLOAK_LOGLEVEL=WARN
KEYCLOAK_STATISTICS=db

# ============================================================================
# Graylog Configuration (Centralized Logging)
# ============================================================================

# Generate with: openssl rand -base64 32
GRAYLOG_PASSWORD_SECRET=change_me_to_secure_password

# Generate with: echo -n "password" | sha256sum
GRAYLOG_ROOT_PASSWORD_SHA2=8c6976e5b5410415bde908bd4dee15dfb167a9c873fc4bb8a81f6f2ab448a918

# ============================================================================
# Grafana Configuration (Dashboards & Monitoring)
# ============================================================================
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_to_secure_password
GRAFANA_ALLOW_SIGN_UP=false
GRAFANA_ANONYMOUS_ENABLED=false

# ============================================================================
# Prometheus Configuration (Metrics Collection)
# ============================================================================
PROMETHEUS_RETENTION=30d
PROMETHEUS_EVALUATION_INTERVAL=15s
PROMETHEUS_SCRAPE_INTERVAL=15s

# ============================================================================
# Backend Application Configuration
# ============================================================================
PORT=4000
LOG_LEVEL=info

# Kroger API Integration (optional)
KROGER_CLIENT_ID=
KROGER_CLIENT_SECRET=
KROGER_REDIRECT_URI=https://family-planner.example.com/api/kroger/callback

# ============================================================================
# Performance Tuning
# ============================================================================

# Connection Pool Settings
DB_CONNECTION_POOL_MIN=2
DB_CONNECTION_POOL_MAX=20

# Cache TTL (seconds)
CACHE_TTL=3600

# Rate Limiting (requests per minute)
RATE_LIMIT_GLOBAL=1000
RATE_LIMIT_AUTH=20
RATE_LIMIT_API=100

# ============================================================================
# Monitoring & Alerts
# ============================================================================

# Alert Manager Settings
ALERT_EMAIL=ops@example.com
ALERT_SLACK_WEBHOOK=

# ============================================================================
# Backup Configuration
# ============================================================================
BACKUP_SCHEDULE="0 0 * * *"  # Daily at midnight
BACKUP_RETENTION_DAYS=7

# ============================================================================
# SSL/TLS Configuration
# ============================================================================

# Let's Encrypt
LETSENCRYPT_ACCEPT_TOS=true
LETSENCRYPT_STAGING=false  # Set to true for testing (self-signed)

# TLS Ciphers
TLS_MIN_VERSION=1.2

# ============================================================================
# Docker Image Versions (pin for stability)
# ============================================================================

# Use specific tags in production, not 'latest'
# Update docker-compose.prod.yml with these versions

# Base Services
POSTGRES_VERSION=16-alpine
MONGO_VERSION=7.0
REDIS_VERSION=7-alpine
NODE_VERSION=20-alpine

# Infrastructure
TRAEFIK_VERSION=v2.10
PROMETHEUS_VERSION=latest
GRAFANA_VERSION=latest
GRAYLOG_VERSION=5.1
ELASTICSEARCH_VERSION=8.10.0
KEYCLOAK_VERSION=22.0.0

# ============================================================================
# Feature Flags
# ============================================================================

ENABLE_KROGER_INTEGRATION=false
ENABLE_ADVANCED_ANALYTICS=false
ENABLE_AUDIT_LOG=true
ENABLE_RATE_LIMITING=true
ENABLE_CORS=true

# ============================================================================
# Development/Staging Overrides (ONLY for non-production)
# ============================================================================

# DANGER: Only set these to 'true' for staging/dev environments
DEBUG_MODE=false
DISABLE_AUTH=false
ALLOW_INSECURE_HTTP=false
LETSENCRYPT_STAGING=false

# ============================================================================
# IMPORTANT SECURITY NOTES
# ============================================================================

# 1. NEVER commit this file with real values to version control
# 2. Store secrets in environment variables or secrets manager
# 3. Rotate POSTGRES_PASSWORD, REDIS_PASSWORD, JWT_SECRET monthly
# 4. Use strong passwords (20+ characters, mixed case, numbers, symbols)
# 5. Restrict .env.prod file permissions to 600 (chmod 600 .env.prod)
# 6. Use different values for staging and production
# 7. Review this file monthly for unused or outdated settings

# ============================================================================
# Generation Commands
# ============================================================================

# Generate secure random password:
# openssl rand -base64 32

# Generate JWT secret (64 chars):
# openssl rand -base64 64

# Generate Graylog password hash:
# echo -n "your_password" | sha256sum

# ============================================================================
