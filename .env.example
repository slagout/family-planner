# =============================================================================
# Family Planner — Environment Variables Reference
# =============================================================================
# DO NOT put real secrets here. This file is committed to git as a template.
# To configure your instance, run:  ./setup.sh
# =============================================================================

# ── Deployment ────────────────────────────────────────────────────────────────
NODE_ENV=production
DOMAIN=192.168.200.47
SERVER_IP=192.168.200.47

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=family_planner
POSTGRES_USER=fp_user
POSTGRES_PASSWORD=                 # generate: openssl rand -base64 24

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=                    # generate: openssl rand -base64 20

# ── Application ───────────────────────────────────────────────────────────────
JWT_SECRET=                        # generate: openssl rand -hex 32  (min 32 chars)
PORT=4000
CORS_ORIGINS=https://192.168.200.47

# ── Keycloak ──────────────────────────────────────────────────────────────────
KEYCLOAK_REALM=family-planner
KEYCLOAK_CLIENT_ID=family-planner-backend
KEYCLOAK_CLIENT_SECRET=            # generate: openssl rand -hex 24
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=           # generate: openssl rand -base64 16

# ── Kroger Integration ────────────────────────────────────────────────────────
# Register at https://developer.kroger.com to get these values
KROGER_CLIENT_ID=
KROGER_CLIENT_SECRET=
KROGER_REDIRECT_URI=https://192.168.200.47/api/kroger/callback

# ── Token Encryption (AES-256-GCM) ───────────────────────────────────────────
# generate: openssl rand -hex 32  (must be exactly 64 hex characters)
# WARNING: rotating this key requires TRUNCATE kroger_tokens (users re-link Kroger)
KROGER_TOKEN_ENCRYPTION_KEY=

# ── TLS / HTTPS ───────────────────────────────────────────────────────────────
# For Let's Encrypt (public domain): set email and run ./scripts/ssl/setup-ssl.sh
# For LAN/IP: run ./scripts/ssl/setup-ssl.sh --lan  (uses mkcert, no email needed)
LETSENCRYPT_EMAIL=
