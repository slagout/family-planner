# ===========================================================================
# ⚠️  DEPLOYMENT CHECKLIST — Replace ALL placeholder values before deploying
# ===========================================================================
# Steps:
#   1. Copy this file:  cp .env.example .env
#   2. Generate secrets (see commands below) and fill them in
#   3. NEVER commit your .env file — it is already listed in .gitignore
# ===========================================================================

# --- Database ---
POSTGRES_DB=family_planner
POSTGRES_USER=fp_user
# ⚠️  REQUIRED — Generate with:  node -e "process.stdout.write(require('crypto').randomBytes(24).toString('base64url'))"
POSTGRES_PASSWORD=changeme_to_secure_password

# --- JWT ---
# ⚠️  REQUIRED (min 32 chars) — Generate with:
#   node -e "process.stdout.write(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=changeme_to_random_32char_string

# --- Kroger OAuth2 ---
# ⚠️  REQUIRED for Kroger integration — obtain from https://developer.kroger.com
# If left empty the server will start, but /api/kroger/* endpoints will return 503.
KROGER_CLIENT_ID=
KROGER_CLIENT_SECRET=
KROGER_REDIRECT_URI=http://localhost:4000/api/kroger/callback
# ⚠️  REQUIRED for Kroger token encryption — must be a 64-character hex string.
# Generate with:  node -e "process.stdout.write(require('crypto').randomBytes(32).toString('hex'))"
KROGER_TOKEN_ENCRYPTION_KEY=

# --- Home Assistant Integration ---
# ⚠️  REQUIRED to use /api/ha/* endpoints (Family Planner → HA dashboard cards)
# Generate with:  node -e "process.stdout.write(require('crypto').randomBytes(32).toString('hex'))"
# Then set Authorization: Bearer <this value> in your HA configuration.yaml rest: block
HA_API_TOKEN=

# --- Encryption (AES-256-GCM for tokens at rest) ---
# ⚠️  REQUIRED for Kroger token storage — Generate with:
#   node -e "process.stdout.write(require('crypto').randomBytes(48).toString('base64url'))"
ENCRYPTION_KEY=changeme_to_a_strong_random_secret

# --- App ---
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000,http://frontend
FRONTEND_URL=http://localhost:5173
PORT=4000
