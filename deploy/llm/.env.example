# =============================================================================
# Family Planner — LLM Service Environment Configuration
# cp .env.example .env  and edit values before running docker compose
# =============================================================================

# Port Ollama listens on the host (default: 11434)
LLM_PORT=11434

# Model to pull on first start.
# RAM requirements (no GPU):
#   llama3:8b    ~8 GB  — good general-purpose model, works on CPU
#   mistral:7b   ~7 GB  — fast, high quality
#   phi3:mini    ~4 GB  — lightweight, good for limited hardware
#   llama3:70b   ~48 GB — best quality, requires GPU or very large RAM
DEFAULT_MODEL=llama3:8b

# CORS origins allowed to query Ollama directly.
# Restrict to your backend domain in production.
# Example: https://api.family-planner.example.com
ALLOWED_ORIGINS=*
