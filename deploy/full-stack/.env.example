# Full-stack local dev env — safe defaults for development only
# Copy: cp .env.example .env

POSTGRES_DB=family_planner
POSTGRES_USER=fp_user
POSTGRES_PASSWORD=dev_password_change_me

# Must be at least 32 chars for JWT validation to pass
JWT_SECRET=dev_jwt_secret_min_32_chars_long_placeholder

# Kroger optional — leave blank to disable
KROGER_CLIENT_ID=
KROGER_CLIENT_SECRET=
KROGER_TOKEN_ENCRYPTION_KEY=
