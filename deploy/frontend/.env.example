# =============================================================================
# Family Planner Frontend — Environment Configuration
# cp .env.example .env  and fill in values before running docker compose
# =============================================================================

# ⚠️  REQUIRED: Full URL of the backend API
# Examples:
#   Centrally hosted:  https://api.family-planner.example.com
#   Self-hosted LAN:   http://192.168.1.100:4000
#   Local dev:         http://localhost:4000
API_URL=https://api.your-backend.com

# Port to expose the frontend on the host (default: 80)
FRONTEND_PORT=80

# Domain name for optional Traefik TLS termination (leave blank if not using Traefik)
DOMAIN=your-domain.com
