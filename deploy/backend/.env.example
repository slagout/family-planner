# =============================================================================
# Family Planner Backend — Environment Configuration
# cp .env.example .env  and fill in ALL ⚠️ REQUIRED values before deploying
# =============================================================================

# --- PostgreSQL ---------------------------------------------------------------
POSTGRES_DB=family_planner
POSTGRES_USER=fp_user
# ⚠️  REQUIRED — Generate:
#   node -e "process.stdout.write(require('crypto').randomBytes(24).toString('base64url'))"
POSTGRES_PASSWORD=

# --- JWT ----------------------------------------------------------------------
# ⚠️  REQUIRED (min 32 chars) — Generate:
#   node -e "process.stdout.write(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=

# --- CORS (which frontend origins are allowed) --------------------------------
# Comma-separated list. Must include the URL clients access the frontend from.
# Example: https://app.example.com,https://www.example.com
CORS_ORIGINS=https://your-frontend-domain.com

# --- Let's Encrypt (Traefik auto-TLS) -----------------------------------------
ACME_EMAIL=you@example.com

# --- Kroger OAuth2 (optional) -------------------------------------------------
# Obtain credentials at https://developer.kroger.com
# Leave blank to disable Kroger integration (server still starts normally).
KROGER_CLIENT_ID=
KROGER_CLIENT_SECRET=
KROGER_REDIRECT_URI=https://api.your-backend.com/api/kroger/callback
# ⚠️  REQUIRED if Kroger is enabled — 64-char hex string
# Generate: node -e "process.stdout.write(require('crypto').randomBytes(32).toString('hex'))"
KROGER_TOKEN_ENCRYPTION_KEY=

# --- LLM (optional, --profile llm) -------------------------------------------
# Internal URL — leave as-is if using the built-in fp-llm service
LLM_API_URL=http://fp-llm:11434
